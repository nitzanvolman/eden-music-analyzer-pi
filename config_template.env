# SC-OSC configuration
# Sourced by autostart.sh and systemd service.
# Read by analyzer.scd via environment variables.
#
# Copy this file to config.env and uncomment/edit values as needed.
# All values shown are the defaults used when unset.

# ==============================================================================
# OSC destinations — where analysis messages are sent
# ==============================================================================

# Comma-separated list of ip:port pairs. Messages are sent to ALL destinations.
# Example: SC_OSC_DESTINATIONS=127.0.0.1:9000,192.168.1.50:9000,10.0.0.5:7000
SC_OSC_DESTINATIONS=127.0.0.1:9000

# Legacy single-destination variables (used only if SC_OSC_DESTINATIONS is not set)
# SC_OSC_DEST_IP=127.0.0.1
# SC_OSC_DEST_PORT=9000

# ==============================================================================
# Audio input
# ==============================================================================

# JACK audio device (run 'aplay -l' to list devices)
# SC_JACK_DEVICE=hw:0

# Audio input channel index (0 = first channel, 1 = second, etc.)
# SC_AUDIO_INPUT_CHANNEL=0

# ==============================================================================
# Input conditioning
# ==============================================================================
# Signal chain applied before all analysis: Gain → HPF → Noise Gate → Compressor.
# Default values are transparent (no effect). Tune these for live recordings
# with ambient noise (wind, crowd, generators — e.g., Burning Man DJ sets).

# Overall input gain multiplier. 1.0 = unity. 0.5 = half, 2.0 = double.
# Use to normalize quiet or hot recordings so thresholds work consistently.
# SC_INPUT_GAIN=1.0

# High-pass filter cutoff in Hz. Removes rumble below this frequency.
# 20 Hz default is inaudible. Set to 30–40 for wind/generator rumble.
# SC_HPF_FREQ=20

# Noise gate threshold in dB. Signal below this level is silenced.
# -96 = effectively off. Set to -40 to -30 for noisy environments.
# Prevents false onset triggers during quiet passages / breakdowns.
# SC_NOISE_GATE_THRESHOLD=-96

# Noise gate envelope times in seconds
# SC_NOISE_GATE_ATTACK=0.01
# SC_NOISE_GATE_RELEASE=0.1

# Compressor: tames dynamic range so quiet and loud sections analyze consistently.
# 0 = disabled (default), 1 = enabled.
# SC_COMPRESSOR_ENABLED=0

# Compressor threshold in dB (compress signals above this level)
# SC_COMPRESSOR_THRESHOLD=-12

# Compressor ratio (3 = 3:1 compression)
# SC_COMPRESSOR_RATIO=3

# Compressor envelope times in seconds
# SC_COMPRESSOR_ATTACK=0.01
# SC_COMPRESSOR_RELEASE=0.1

# ==============================================================================
# FFT
# ==============================================================================

# FFT buffer size in samples. Larger = better frequency resolution, more latency.
# 2048 at 44100 Hz ≈ 46ms window. Options: 512, 1024, 2048, 4096
# Note: KeyTrack (key detection) requires 4096. Smaller sizes degrade key accuracy.
# SC_FFT_SIZE=2048

# ==============================================================================
# Amplitude
# ==============================================================================

# How fast amplitude reacts to volume increases (seconds)
# SC_AMP_ATTACK_TIME=0.01

# How fast amplitude reacts to volume decreases (seconds)
# SC_AMP_RELEASE_TIME=0.1

# ==============================================================================
# Pitch detection
# ==============================================================================

# Minimum detectable frequency in Hz (lower = catches more bass)
# SC_PITCH_MIN_FREQ=50

# Maximum detectable frequency in Hz
# SC_PITCH_MAX_FREQ=4000

# ==============================================================================
# Scene change detection
# ==============================================================================
# PV_HainsworthFoote spectral novelty detector — fires a trigger when the
# spectral content changes significantly (breakdowns, drops, track transitions).

# Threshold for scene change trigger (higher = fewer, more dramatic changes)
# SC_SCENE_THRESHOLD=1.0

# ==============================================================================
# Energy direction (building up / breaking down)
# ==============================================================================
# Compares short-term energy envelope to long-term energy envelope.
# Outputs a continuous value: positive = building up, negative = breaking down.

# Short-term envelope release time in seconds (how fast "now" energy reacts)
# SC_ENERGY_FAST_RELEASE=0.5

# Long-term envelope release time in seconds (how slowly "average" energy tracks)
# SC_ENERGY_SLOW_RELEASE=8.0

# ==============================================================================
# Onset detection suite
# ==============================================================================
# Multiple onset detectors run in parallel, each tuned for a distinct musical
# event using different algorithms and frequency bands.
#
# Algorithms:  mkl = percussive transients, phase = pitched note changes,
#              rcomplex = general purpose, power = raw energy spikes.
#
# Each channel can be enabled/disabled independently. Disabled channels use
# no CPU. The master toggle SC_FEATURE_ONSET_SUITE (in Feature toggles below)
# gates the entire suite.

# --- Percussive channels (mkl algorithm) ---

# Kick drum / bass drum (LPF 100 Hz)
# SC_ONSET_KICK=1
# SC_ONSET_KICK_THRESHOLD=0.3

# Snare, claps, rim shots (BPF 200–2000 Hz)
# SC_ONSET_SNARE=1
# SC_ONSET_SNARE_THRESHOLD=0.4

# Hi-hats, cymbals, shakers (HPF 5000 Hz)
# SC_ONSET_HIHAT=1
# SC_ONSET_HIHAT_THRESHOLD=0.3

# Any sharp percussive hit (full spectrum)
# SC_ONSET_PERC=1
# SC_ONSET_PERC_THRESHOLD=0.4

# --- Melodic channels (phase algorithm) ---

# Bass note changes — synth bass, bass guitar (LPF 200 Hz)
# SC_ONSET_BASS=1
# SC_ONSET_BASS_THRESHOLD=0.7

# Vocal/synth/lead note changes (BPF 300–4000 Hz)
# SC_ONSET_MELODY=1
# SC_ONSET_MELODY_THRESHOLD=0.7

# High-pitched melodic changes, arpeggios (HPF 3000 Hz)
# SC_ONSET_BRIGHT=1
# SC_ONSET_BRIGHT_THRESHOLD=0.7

# --- General / energy channels ---

# Catch-all — any onset of any kind (rcomplex, full spectrum)
# SC_ONSET_ANY=1
# SC_ONSET_ANY_THRESHOLD=0.5

# Big energy spikes — drops, impacts, explosions (power, full spectrum)
# SC_ONSET_DROP=0
# SC_ONSET_DROP_THRESHOLD=0.8

# Only the most obvious, unmistakable onsets (rcomplex, full spectrum, high threshold)
# SC_ONSET_SOFT=0
# SC_ONSET_SOFT_THRESHOLD=0.9

# ==============================================================================
# MFCC (timbre)
# ==============================================================================

# Number of MFCC coefficients (fewer = less CPU, more = finer detail)
# SC_MFCC_NUM_COEFF=13

# ==============================================================================
# Key detection
# ==============================================================================

# Key tracking decay/smoothing time in seconds (higher = more stable)
# SC_KEY_DECAY_TIME=2.0

# ==============================================================================
# Beat tracking
# ==============================================================================

# Beat tracker lock mode: 0 = free (adapts quickly), 1 = locked (steady tempo)
# SC_BEAT_LOCK=0

# ==============================================================================
# Trigger rates (how often each feature group sends OSC, in Hz)
# ==============================================================================

# Fast features: amplitude, pitch, loudness, centroid, flatness
# SC_TRIG_RATE_FAST=30

# Medium features: MFCC, chromagram
# SC_TRIG_RATE_MEDIUM=10

# Slow features: key detection
# SC_TRIG_RATE_SLOW=2

# ==============================================================================
# Feature toggles (1 = enabled, 0 = disabled)
# ==============================================================================

# Disable features to conserve CPU. Disabled features are excluded from the
# SynthDef graph entirely — no UGen computation, no SendReply, no OSCdef.
# SC_FEATURE_AMPLITUDE=1
# SC_FEATURE_PITCH=1
# SC_FEATURE_LOUDNESS=1
# SC_FEATURE_CENTROID=1
# SC_FEATURE_FLATNESS=1
# SC_FEATURE_ONSET_SUITE=1
# SC_FEATURE_MFCC=1
# SC_FEATURE_KEY=1
# SC_FEATURE_BEAT=1
# SC_FEATURE_CHROMA=1
# SC_FEATURE_SCENE=1
# SC_FEATURE_ENERGY=1

# ==============================================================================
# Test mode
# ==============================================================================

# When set to 1, bypass audio input entirely and send synthetic OSC messages
# on all channels. Useful for testing receivers without audio hardware.
# Does not require scsynth or an audio device.
# SC_TEST_MODE=0

# ==============================================================================
# Web interface
# ==============================================================================

# Port for the web server (default 8080)
# SC_WEB_PORT=8080

# Port for the OSC bridge listener (receives data from analyzer, default 9000)
# Must match the first destination in SC_OSC_DESTINATIONS
# SC_OSC_BRIDGE_PORT=9000
